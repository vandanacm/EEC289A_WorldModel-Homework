{
  "benchmark_name": "SmallWorld-Lite Dynamics Benchmark",
  "paper_reference": "SmallWorlds: Assessing Dynamics Understanding of World Models in Isolated Environments",
  "seed": 7,
  "tasks": [
    "free_fall",
    "projectile",
    "circular_motion",
    "inclined_plane",
    "simple_pendulum",
    "rolling",
    "rotation",
    "spin",
    "elastic_collision",
    "bouncing_ball"
  ],
  "dataset": {
    "default_output_dir": "artifacts/smallworld_data",
    "episode_steps": 110,
    "split_episodes": {
      "train": 64,
      "val": 16,
      "test": 16,
      "ood": 16
    }
  },
  "world_model": {
    "embed_dim": 64,
    "deter_dim": 128,
    "stoch_dim": 16,
    "hidden_dim": 128,
    "free_nats": 1.0,
    "kl_scale": 1.0,
    "rep_kl_scale": 0.1,
    "state_loss_scale": 1.0,
    "prior_state_loss_scale": 0.25,
    "learning_rate": 0.0008,
    "grad_clip": 100.0
  },
  "training": {
    "updates": 600,
    "batch_size": 32,
    "batch_length": 32,
    "eval_every_updates": 100
  },
  "evaluation": {
    "warmup_steps": 10,
    "open_loop_horizon": 90,
    "batch_size": 64,
    "metrics": {
      "one_step_state_rmse": {
        "weight": 0.2,
        "good": 0.03,
        "bad": 0.5
      },
      "open_loop_15_rmse": {
        "weight": 0.2,
        "good": 0.08,
        "bad": 1.0
      },
      "open_loop_90_rmse": {
        "weight": 0.25,
        "good": 0.2,
        "bad": 2.5
      },
      "horizon_error_auc": {
        "weight": 0.2,
        "good": 0.12,
        "bad": 1.6
      },
      "ood_open_loop_90_rmse": {
        "weight": 0.15,
        "good": 0.35,
        "bad": 3.0
      }
    }
  },
  "smoke": {
    "episode_steps": 110,
    "split_episodes": {
      "train": 8,
      "val": 4,
      "test": 4,
      "ood": 4
    },
    "updates": 20,
    "batch_size": 4,
    "batch_length": 16,
    "eval_every_updates": 10
  },
  "student_modification_boundary": [
    "smallworld_hw/models.py",
    "smallworld_hw/tasks.py",
    "configs/smallworld_config.json",
    "world_model_hw/models.py",
    "world_model_hw/agent.py",
    "configs/course_config.json"
  ]
}
