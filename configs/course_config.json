{
  "homework_name": "Dreamer World Model Colab Homework",
  "algorithm": "MiniDreamer",
  "framework": "PyTorch + Gymnasium",
  "seed": 0,
  "env": {
    "name": "Pendulum-v1",
    "max_episode_steps": 200,
    "normalize_actions": true
  },
  "replay": {
    "capacity_steps": 100000,
    "prefill_steps": 1000,
    "batch_size": 16,
    "batch_length": 32
  },
  "world_model": {
    "embed_dim": 64,
    "deter_dim": 128,
    "stoch_dim": 16,
    "hidden_dim": 128,
    "free_nats": 1.0,
    "kl_scale": 1.0,
    "rep_kl_scale": 0.1,
    "obs_loss_scale": 1.0,
    "reward_loss_scale": 1.0,
    "continue_loss_scale": 0.1,
    "learning_rate": 0.0006,
    "grad_clip": 100.0
  },
  "actor_critic": {
    "hidden_dim": 128,
    "imag_horizon": 15,
    "discount": 0.99,
    "lambda": 0.95,
    "actor_learning_rate": 0.00008,
    "critic_learning_rate": 0.0003,
    "entropy_scale": 0.0003,
    "min_std": 0.1,
    "target_update_interval": 100,
    "target_update_tau": 0.05,
    "grad_clip": 100.0
  },
  "training_stages": {
    "baseline": {
      "name": "baseline",
      "env_steps": 100000,
      "collect_steps_per_iter": 100,
      "train_updates_per_iter": 8,
      "eval_every_env_steps": 5000,
      "eval_episodes": 5,
      "exploration_std": 0.3
    },
    "local_smoke": {
      "name": "local_smoke",
      "env_steps": 2000,
      "collect_steps_per_iter": 50,
      "train_updates_per_iter": 2,
      "eval_every_env_steps": 500,
      "eval_episodes": 2,
      "exploration_std": 0.5,
      "replay_overrides": {
        "prefill_steps": 200,
        "batch_size": 4,
        "batch_length": 8
      },
      "model_overrides": {
        "embed_dim": 32,
        "deter_dim": 32,
        "stoch_dim": 8,
        "hidden_dim": 64
      },
      "actor_critic_overrides": {
        "hidden_dim": 64,
        "imag_horizon": 5
      }
    }
  },
  "course_budget": {
    "baseline_env_steps": 100000,
    "leaderboard_max_env_steps": 250000,
    "single_final_submission": true,
    "colab_gpu_optional": true
  },
  "public_eval": {
    "num_episodes": 8,
    "open_loop_horizon": 15,
    "metrics": {
      "mean_return": {
        "direction": "higher_better",
        "weight": 0.45,
        "good": -200.0,
        "bad": -1600.0
      },
      "one_step_obs_rmse": {
        "direction": "lower_better",
        "weight": 0.2,
        "good": 0.08,
        "bad": 0.75
      },
      "open_loop_obs_rmse": {
        "direction": "lower_better",
        "weight": 0.2,
        "good": 0.25,
        "bad": 1.5
      },
      "reward_mae": {
        "direction": "lower_better",
        "weight": 0.1,
        "good": 0.2,
        "bad": 5.0
      },
      "action_delta": {
        "direction": "lower_better",
        "weight": 0.05,
        "good": 0.05,
        "bad": 0.9
      }
    }
  },
  "files_to_read_first": [
    "world_model_hw/models.py",
    "world_model_hw/agent.py",
    "train.py",
    "public_eval.py"
  ],
  "submission": {
    "required_files": [
      "best_checkpoint/",
      "configs/colab_runtime_config.json",
      "public_eval.json",
      "demo_policy.mp4_or_gif",
      "world_model_rollout.png",
      "short_report.pdf"
    ],
    "report_required_questions": [
      "Explain the RSSM world model and the actor-critic imagination loop.",
      "Describe the baseline curves and public metrics.",
      "Describe what you changed and why.",
      "Report which metrics improved or worsened.",
      "Describe at least one failed idea and what you learned from it."
    ]
  }
}

