<mujoco model="simple_pendulum">
  <option timestep="0.04" gravity="0 0 -9.81"/>
  <visual><global offwidth="320" offheight="240"/></visual>
  <worldbody>
    <light pos="0 -4 5"/>
    <camera name="track" pos="0 -5 2.5" xyaxes="1 0 0 0 0.45 0.89"/>
    <body name="pendulum" pos="0 0 1.6">
      <joint name="hinge" type="hinge" axis="0 1 0" damping="0.02"/>
      <geom type="capsule" fromto="0 0 0 0 0 -1" size="0.025" mass="0.1" rgba="0.2 0.2 0.2 1"/>
      <geom name="bob" type="sphere" pos="0 0 -1" size="0.12" mass="1" rgba="0.9 0.7 0.1 1"/>
    </body>
  </worldbody>
  <actuator><motor name="torque" joint="hinge" gear="1"/></actuator>
</mujoco>
