<mujoco model="rolling">
  <option timestep="0.04" gravity="0 0 -9.81"/>
  <visual><global offwidth="320" offheight="240"/></visual>
  <worldbody>
    <light pos="0 -4 5"/>
    <camera name="track" pos="3 -6 3" xyaxes="1 0 0 0 0.55 0.83"/>
    <geom name="floor" type="plane" size="5 2 0.1" rgba="0.85 0.85 0.85 1" friction="1 0.01 0.01"/>
    <body name="roller" pos="0 0 0.25">
      <joint name="slide_x" type="slide" axis="1 0 0" damping="0.01"/>
      <joint name="roll" type="hinge" axis="0 1 0" damping="0.01"/>
      <geom name="cylinder" type="cylinder" size="0.25 0.25" euler="1.5708 0 0" mass="1" rgba="0.4 0.6 0.9 1"/>
    </body>
  </worldbody>
  <actuator>
    <motor name="force_x" joint="slide_x" gear="1"/>
    <motor name="torque_roll" joint="roll" gear="1"/>
  </actuator>
</mujoco>
